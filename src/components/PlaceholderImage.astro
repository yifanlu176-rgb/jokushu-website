---
interface Props {
  icon?: string;
  width?: number;
  height?: number;
  bgColor?: string;
  iconColor?: string;
}

const {
  icon = '☰',
  width = 400,
  height = 300,
  bgColor = '#181510',
  iconColor = '#c9a553'
} = Astro.props;
---

<svg
  width={width}
  height={height}
  viewBox={`0 0 ${width} ${height}`}
  xmlns="http://www.w3.org/2000/svg"
>
  <!-- Background -->
  <rect width="100%" height="100%" fill={bgColor} />

  <!-- Pattern -->
  <defs>
    <pattern id="pattern" x="0" y="0" width="40" height="40" patternUnits="userSpaceOnUse">
      <line x1="0" y1="0" x2="40" y2="40" stroke={iconColor} stroke-width="0.5" opacity="0.1" />
      <line x1="40" y1="0" x2="0" y2="40" stroke={iconColor} stroke-width="0.5" opacity="0.1" />
    </pattern>
  </defs>
  <rect width="100%" height="100%" fill="url(#pattern)" />

  <!-- Icon -->
  <text
    x="50%"
    y="50%"
    text-anchor="middle"
    dominant-baseline="middle"
    font-size="80"
    fill={iconColor}
    opacity="0.3"
  >
    {icon}
  </text>
</svg>
